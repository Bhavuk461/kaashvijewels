# Frontend (Vite) environment variables.
# Copy to .env.local for local dev, and configure as build env for deploys.

# Public Razorpay Key ID (safe to expose). NOT the key secret.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Base URL of the deployed Cloudflare Worker (no trailing slash).
# e.g. https://kaashvi-payments.<your-subdomain>.workers.dev
VITE_WORKER_URL=https://kaashvi-payments.example.workers.dev
